# Support API base URL for the contact / submit-request form (no trailing slash).
# Used for presigned URL endpoint and submit request.
VITE_SUPPORT_API_BASE_URL=

# reCAPTCHA: site key (frontend).
# Must match API secret key server-side. If unset, form sends a placeholder; API skips verify.
VITE_RECAPTCHA_SITE_KEY=

# Optional: platform/environment for Jira (e.g. dev, staging, prod). Default: dev
VITE_PLATFORM=dev

